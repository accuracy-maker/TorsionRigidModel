<?xml version="1.0" ?>
<Node name="root" dt="0.01" gravity="0 0 0">

    <RequiredPlugin name="TorsionRigidModel"/>
    <RequiredPlugin name="Sofa.Component.Visual"/>
    <RequiredPlugin name="Sofa.Component.AnimationLoop"/>

    <DefaultAnimationLoop/>
    <VisualStyle displayFlags="showVisualModels"/>

    <!-- zNear/zFar fix the clipping at any rotation angle without needing addBBox() in C++ -->
    <!-- <InteractiveCamera position="44 -500 113" lookAt="44 0 113" fieldOfView="40"
                       zNear="1" zFar="5000"/> -->

    <!-- FK engine -->
    <TRMForwardKinematicsEngine name="fk"
        d_jointConfig="0 50 0 50 0 50"/>

    <!-- Visual model: draws the backbone wired from FK output -->
    <TRMVisualModel name="visual"
        d_jointConfig="@fk.d_jointConfig"
        d_nSamples="30"/>

</Node>
